# ==============================================================================
# SOFTKEY ENTERPRISE - ENVIRONMENT VARIABLES SPECIFICATION (.env.example)
# ==============================================================================
# Instructions:
# 1. Copy this file to '.env' in your local development environment.
# 2. Fill in the values for your integrations. Do not commit actual credentials.
# 3. For Netlify/Cloud Run deployments, configure these in your provider's dashboard.
# ==============================================================================

# --- PLATFORM CONFIGURATION ---
# GEMINI_API_KEY: Required for Gemini AI assistant.
# AI Studio automatically injects this. Set here only for standalone deployment.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet/website is hosted (e.g., https://yourdomain.com).
# Used for order invoice emails, customer callbacks, and API referrers.
APP_URL=""

# JWT_SECRET: Private key used to sign and verify secure session JSON Web Tokens.
# Choose a strong custom random string for production.
JWT_SECRET=""

# --- INTEGRATIONS ---

# 1. SUPABASE DATABASE & AUTHENTICATION
# SUPABASE_URL: The secure URL of your Supabase project (e.g., https://xyz.supabase.co)
SUPABASE_URL=""

# SUPABASE_SERVICE_ROLE_KEY: The secret service_role key (bypasses RLS, used by backend server)
SUPABASE_SERVICE_ROLE_KEY=""

# VITE_SUPABASE_URL: Client-side copy of the Supabase URL
VITE_SUPABASE_URL=""

# VITE_SUPABASE_ANON_KEY: Client-side anonymous public key of your Supabase project
VITE_SUPABASE_ANON_KEY=""

# 2. RAZORPAY GATEWAY
# RAZORPAY_KEY_ID: Razorpay public API key
RAZORPAY_KEY_ID=""

# RAZORPAY_SECRET: Razorpay private API secret key
RAZORPAY_SECRET=""

# RAZORPAY_WEBHOOK_SECRET: Secret for verifying signature of webhook events
RAZORPAY_WEBHOOK_SECRET=""

# 3. 2FACTOR SMS OTP GATEWAY
# TWO_FACTOR_API_KEY: API Key for 2Factor.in SMS OTP gateway service
TWO_FACTOR_API_KEY=""

# 4. WHATSAPP CLOUD API (META)
# WHATSAPP_API_TOKEN: Permanent API developer token from Meta Developers
WHATSAPP_API_TOKEN=""

# WHATSAPP_PHONE_NUMBER_ID: Phone number ID from WhatsApp Business settings
WHATSAPP_PHONE_NUMBER_ID=""

# WHATSAPP_BUSINESS_ID: WhatsApp Business Account ID
WHATSAPP_BUSINESS_ID=""

# WHATSAPP_TEMPLATE_LANGUAGE: Language code for WhatsApp message templates (e.g., en, hi)
WHATSAPP_TEMPLATE_LANGUAGE=""

# 5. SMTP EMAIL DELIVERY
# SMTP_HOST: Outgoing mail server (e.g., mail.yourdomain.com, smtp.hostinger.com, or smtp.gmail.com)
SMTP_HOST=""

# SMTP_USER: Full email address login for SMTP (e.g., info@yourdomain.com)
SMTP_USER=""

# SMTP_PASSWORD: Password for SMTP email account
SMTP_PASSWORD=""

# --- WHATSAPP META TEMPLATE OVERRIDES ---
# (Leave empty to use built-in defaults or configure to match your Meta dashboard)
WHATSAPP_TEMPLATE_REGISTRATION=""
WHATSAPP_TEMPLATE_LOGIN_OTP=""
WHATSAPP_TEMPLATE_PAYMENT_SUCCESS=""
WHATSAPP_TEMPLATE_PAYMENT_FAILED=""
WHATSAPP_TEMPLATE_ORDER_CONFIRMATION=""
WHATSAPP_TEMPLATE_LICENSE_KEY_DELIVERY=""
WHATSAPP_TEMPLATE_SOFTWARE_DOWNLOAD=""
WHATSAPP_TEMPLATE_SHIPPING_UPDATE=""
WHATSAPP_TEMPLATE_DELIVERY_CONFIRMATION=""
WHATSAPP_TEMPLATE_REFUND_INITIATED=""
WHATSAPP_TEMPLATE_REFUND_COMPLETED=""
WHATSAPP_TEMPLATE_LOW_STOCK_ALERTS=""
WHATSAPP_TEMPLATE_NEW_ORDER_NOTIFICATIONS=""
